{% extends 'base.html.twig' %}

{% block title %}{{ 'title.products'|trans }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>{{ 'nav.products'|trans }}</h1>
    {% if is_granted('ROLE_VENDEUR') %}
        <a href="{{ path('app_product_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> {{ 'button.new_product'|trans }}
        </a>
    {% endif %}
</div>

{# Barre de recherche rapide + bouton filtres #}
{{ form_start(searchForm) }}
<div class="d-flex gap-2 mb-2">
    {{ form_widget(searchForm.name, {attr: {class: 'form-control', placeholder: 'Rechercher un produit…'}}) }}
    {{ form_widget(searchForm.sort, {attr: {class: 'form-select w-auto'}}) }}
    <button type="button" class="btn btn-outline-secondary text-nowrap"
            data-bs-toggle="collapse" data-bs-target="#filtresAvances"
            aria-expanded="false">
        <i class="bi bi-sliders"></i> Filtres
    </button>
    <button type="submit" class="btn btn-primary text-nowrap">
        <i class="bi bi-search"></i> Rechercher
    </button>
    <a href="{{ path('app_product_index') }}" class="btn btn-outline-danger" title="Réinitialiser">
        <i class="bi bi-arrow-counterclockwise"></i>
    </a>
</div>

{# Filtres avancés rétractables #}
<div class="collapse mb-3" id="filtresAvances">
    <div class="card card-body">
        <div class="row g-3">
            <div class="col-md-3">
                {{ form_label(searchForm.category, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                {{ form_widget(searchForm.category, {attr: {class: 'form-select form-select-sm'}}) }}
            </div>
            <div class="col-md-2">
                {{ form_label(searchForm.minPrice, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                {{ form_widget(searchForm.minPrice, {attr: {class: 'form-control form-control-sm'}}) }}
            </div>
            <div class="col-md-2">
                {{ form_label(searchForm.maxPrice, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                {{ form_widget(searchForm.maxPrice, {attr: {class: 'form-control form-control-sm'}}) }}
            </div>
            <div class="col-md-2">
                {{ form_label(searchForm.expiresAtAfter, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                {{ form_widget(searchForm.expiresAtAfter, {attr: {class: 'form-control form-control-sm'}}) }}
            </div>
            <div class="col-md-2">
                {{ form_label(searchForm.expiresAtBefore, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                {{ form_widget(searchForm.expiresAtBefore, {attr: {class: 'form-control form-control-sm'}}) }}
            </div>
        </div>
        <div class="mt-3">
            <p class="small fw-semibold mb-2">Tags</p>
            <div class="d-flex flex-wrap gap-2">
                {% for checkbox in searchForm.tags %}
                    <div>
                        {{ form_widget(checkbox, {attr: {class: 'btn-check'}}) }}
                        <label class="btn btn-outline-secondary btn-sm rounded-pill" for="{{ checkbox.vars.id }}">
                            {{ checkbox.vars.label }}
                        </label>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{{ form_end(searchForm) }}

{# Résultats #}
<p class="text-muted small mb-3">{{ products|length }} annonce{{ products|length != 1 ? 's' : '' }} trouvée{{ products|length != 1 ? 's' : '' }}</p>

{% if products|length == 0 %}
    <p class="text-muted">{{ 'empty.no_products'|trans }}</p>
{% else %}
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
        <div class="col">
            <div class="card h-100 shadow-sm">
                {% if product.images|length > 0 %}
                    <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                         class="card-img-top" style="height:200px;object-fit:cover;"
                         alt="{{ product.name }}">
                {% else %}
                    <div class="bg-light d-flex align-items-center justify-content-center"
                         style="height:200px;">
                        <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                {% endif %}
                <div class="card-body">
                    <h5 class="card-title">{{ product.name }}</h5>
                    <p class="card-text text-muted small">
                        <i class="bi bi-tag"></i> {{ product.category.name }}
                        {% for tag in product.tags %}
                            <span class="badge bg-secondary">{{ tag.name }}</span>
                        {% endfor %}
                    </p>
                    <p class="card-text fw-bold fs-5">{{ product.price }} {{ 'format.currency'|trans }}</p>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center gap-2">
                    <small class="text-muted">{{ product.seller.firstName }}</small>
                    {% if app.user and app.user !== product.seller %}
                    <form method="POST" action="{{ path('app_cart_add', {productId: product.id}) }}" class="d-inline">
                        <input type="hidden" name="quantity" value="1">
                        <button type="submit" class="btn btn-sm btn-primary" title="{{ 'button.add_to_cart'|trans }}">
                            <i class="bi bi-bag-plus"></i>
                        </button>
                    </form>
                    {% endif %}
                    <a href="{{ path('app_product_show', {slug: product.slug}) }}"
                       class="btn btn-sm btn-outline-primary">{{ 'button.view'|trans }}</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

