<!-- Add to Cart Form -->
<form method="POST" action="{{ path('app_cart_add', {productId: product.id}) }}" class="add-to-cart-form">
    <input type="hidden" name="_token" value="{{ csrf_token('add_to_cart') }}">
    <div class="input-group">
        <input
            type="number"
            name="quantity"
            class="form-control"
            min="1"
            max="999"
            value="1"
            placeholder="Quantité"
            aria-label="Quantité"
        >
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-bag-plus"></i>{{ 'button.add_to_cart'|trans }}</button>
    </div>
</form>
