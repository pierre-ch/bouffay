{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Dashboard Bouffay{% endblock %}

{% block main %}
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-users me-2"></i> Utilisateurs</h5>
                    <p class="card-text fs-2 fw-bold">{{ users_count }}</p>
                    <a href="{{ path('admin_user_index') }}" class="text-white text-decoration-none">
                        Gérer <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-box me-2"></i> Produits</h5>
                    <p class="card-text fs-2 fw-bold">{{ products_count }}</p>
                    <a href="{{ path('admin_product_index') }}" class="text-white text-decoration-none">
                        Gérer <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-shopping-cart me-2"></i> Commandes</h5>
                    <p class="card-text fs-2 fw-bold">{{ orders_count }}</p>
                    <a href="{{ path('admin_order_index') }}" class="text-white text-decoration-none">
                        Gérer <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-euro-sign me-2"></i> Valeur du Stock</h5>
                    <p class="card-text fs-2 fw-bold">{{ stock_value|number_format(2, ',', ' ') }} €</p>
                    <a href="{{ path('admin_product_index') }}" class="text-dark text-decoration-none">
                        Détails <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-clock me-2 text-muted"></i> 5 dernières commandes</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Client</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for order in recent_orders %}
                                    <tr>
                                        <td>#{{ order.id }}</td>
                                        <td>{{ order.buyer.firstName }} {{ order.buyer.lastName }}</td>
                                        <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                                        <td>{{ order.totalPrice }} €</td>
                                        <td>
                                            <span class="badge bg-secondary">{{ order.globalStatus }}</span>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-3">Aucune commande pour le moment.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    <div class="row mt-4">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-list me-2 text-muted"></i> Répartition du stock par catégorie</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Catégorie</th>
                                    <th class="text-end">Valeur du stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in stock_by_category %}
                                    <tr>
                                        <td>{{ item.category_name ?: 'Non catégorisé' }}</td>
                                        <td class="text-end fw-semibold">{{ item.total_value|number_format(2, ',', ' ') }} €</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="2" class="text-center text-muted py-3">Aucune donnée disponible.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <th class="text-end">Total général</th>
                                    <th class="text-end fs-5">{{ stock_value|number_format(2, ',', ' ') }} €</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2 text-muted"></i> Graphique de répartition</h5>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    <div style="position: relative; height:300px; width:100%">
                        <canvas id="stockChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block body_javascript %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function initStockChart() {
            const canvas = document.getElementById('stockChart');
            if (!canvas) return;
            
            if (window.stockChartInstance) {
                window.stockChartInstance.destroy();
            }

            const ctx = canvas.getContext('2d');
            const data = {{ stock_by_category|json_encode|raw }};
            
            const labels = data.map(item => item.category_name || 'Non catégorisé');
            const values = data.map(item => parseFloat(item.total_value));
            
            window.stockChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Valeur du stock (€)',
                        data: values,
                        backgroundColor: [
                            '#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b',
                            '#858796', '#5a5c69', '#2e59d9', '#17a673', '#2c9faf'
                        ],
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                        }
                    }
                }
            });
        }

        document.addEventListener('turbo:load', initStockChart);
        document.addEventListener('DOMContentLoaded', initStockChart);
        initStockChart();
    </script>
{% endblock %}
