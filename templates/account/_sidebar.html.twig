{% set route = app.request.attributes.get('_route') %}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="p-3 border-bottom text-center">
            <i class="bi bi-person-circle fs-1 text-secondary"></i>
            <div class="fw-semibold mt-1">{{ app.user.firstName }} {{ app.user.lastName }}</div>
            <div class="text-muted small">{{ app.user.email }}</div>
        </div>
        <ul class="list-group list-group-flush">
            <li class="list-group-item list-group-item-action {% if route == 'app_account' %}active{% endif %}">
                <a href="{{ path('app_account') }}" class="text-decoration-none {% if route == 'app_account' %}text-white{% endif %}">
                    <i class="bi bi-speedometer2 me-2"></i>{{ 'nav.dashboard'|trans }}
                </a>
            </li>
            <li class="list-group-item list-group-item-action {% if route == 'app_account_profile' %}active{% endif %}">
                <a href="{{ path('app_account_profile') }}" class="text-decoration-none {% if route == 'app_account_profile' %}text-white{% endif %}">
                    <i class="bi bi-person me-2"></i>{{ 'nav.my_profile'|trans }}</a>
            </li>
            <li class="list-group-item list-group-item-action {% if route starts with 'app_account_order' %}active{% endif %}">
                <a href="{{ path('app_account_orders') }}" class="text-decoration-none {% if route starts with 'app_account_order' %}text-white{% endif %}">
                    <i class="bi bi-bag me-2"></i>{{ 'nav.my_orders'|trans }}</a>
            </li>
            <li class="list-group-item list-group-item-action {% if route == 'app_account_favorites' %}active{% endif %}">
                <a href="{{ path('app_account_favorites') }}" class="text-decoration-none {% if route == 'app_account_favorites' %}text-white{% endif %}">
                    <i class="bi bi-heart me-2"></i>{{ 'nav.my_favorites'|trans }}</a>
            </li>
            <li class="list-group-item list-group-item-action {% if route starts with 'app_account_address' %}active{% endif %}">
                <a href="{{ path('app_account_addresses') }}" class="text-decoration-none {% if route starts with 'app_account_address' %}text-white{% endif %}">
                    <i class="bi bi-geo-alt me-2"></i>{{ 'nav.addresses'|trans }}
                </a>
            </li>

        </ul>
    </div>
</div>
