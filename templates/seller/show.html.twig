{% extends 'base.html.twig' %}

{% block title %}{{ seller.firstName }} {{ seller.lastName }} — Bouffay{% endblock %}

{% block body %}
<style>
/* Gradient Banner for Seller Profile */
.seller-banner {
    background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
    border-radius: 2rem;
    position: relative;
    overflow: hidden;
    padding: 4rem 2rem;
    margin-bottom: 3rem;
    box-shadow: 0 1rem 3rem rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
}
[data-bs-theme="dark"] .seller-banner {
    background: linear-gradient(135deg, #432b59 0%, #6b4063 100%);
}
.seller-banner-glass {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 1.5rem;
    padding: 2.5rem 4rem;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.1);
    display: inline-block;
}
[data-bs-theme="dark"] .seller-banner-glass {
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.15);
}

/* Modern Product Card */
.product-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 1.5rem;
    border: none;
}
.product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 1rem 3rem rgba(0,0,0,0.15) !important;
}

/* Modern Review Card */
.review-card {
    border-radius: 1.5rem;
    background: var(--bs-body-tertiary);
    border: none;
    box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.05);
    padding: 1.5rem;
}
</style>

{# En-tête vendeur #}
<div class="seller-banner">
    <div class="seller-banner-glass">
        <h1 class="display-5 fw-bolder mb-2 text-body-emphasis">{{ seller.firstName }} {{ seller.lastName }}</h1>
        <p class="mb-3 fs-5" style="color: var(--bs-body-color); opacity: 0.8;">
            <i class="bi bi-calendar-check me-2"></i>{{ 'info.member_since'|trans }} {{ seller.createdAt|date('F Y') }}
        </p>
        <div class="d-flex align-items-center justify-content-center gap-2">
            <div class="bg-white bg-opacity-75 rounded-pill px-4 py-2 d-inline-flex align-items-center shadow-sm">
                {% if averageRating %}
                    <i class="bi bi-star-fill text-warning me-2 fs-5"></i>
                    <span class="fw-bold fs-5 text-dark">{{ averageRating|number_format(1, ',', ' ') }} <span class="text-muted fs-6 fw-normal">/ 5</span></span>
                    <span class="text-muted small ms-3 border-start border-2 ps-3 border-secondary">
                        {{ reviews|length }} {{ 'info.reviews'|trans }}
                    </span>
                {% else %}
                    <i class="bi bi-star text-muted me-2 fs-5"></i>
                    <span class="text-muted fw-medium">{{ 'empty.no_reviews'|trans }}</span>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="row g-5">
    {# Annonces du vendeur #}
    <div class="col-lg-8">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h3 class="fw-bold mb-0">
                {{ 'title.products'|trans }}
            </h3>
            <span class="badge bg-primary rounded-pill fs-6 px-3 py-2">{{ products|length }}</span>
        </div>

        {% if products|length == 0 %}
            <div class="alert alert-light border-0 shadow-sm rounded-4 text-center p-5">
                <i class="bi bi-box-seam fs-1 text-muted mb-3 d-block"></i>
                <p class="text-muted fs-5 mb-0">{{ 'empty.no_seller_products'|trans }}</p>
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-sm-2 g-4">
                {% for product in products %}
                <div class="col">
                    <div class="card h-100 shadow-sm product-card overflow-hidden">
                        <div class="position-relative">
                            {% if product.images|length > 0 %}
                                <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                                     class="card-img-top" style="height:220px;object-fit:cover;" alt="{{ product.name }}">
                            {% else %}
                                <div class="bg-body-tertiary d-flex align-items-center justify-content-center"
                                     style="height:220px;">
                                    <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                                </div>
                            {% endif %}
                            <div class="position-absolute top-0 end-0 p-3">
                                <span class="badge bg-dark bg-opacity-75 rounded-pill fs-6 px-3 py-2 shadow" style="backdrop-filter: blur(5px);">
                                    {{ product.price }} {{ 'format.currency'|trans }}
                                </span>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold mb-2 text-truncate" title="{{ product.name }}">{{ product.name }}</h5>
                            <div class="mb-0">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1">
                                    <i class="bi bi-tag-fill me-1"></i> {{ product.category.name }}
                                </span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 pb-4 px-4 pt-0">
                            <a href="{{ path('app_product_show', {slug: product.slug}) }}"
                               class="btn btn-outline-primary w-100 rounded-pill fw-bold">{{ 'button.view'|trans }}</a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Avis #}
    <div class="col-lg-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h3 class="fw-bold mb-0">
                {{ 'info.reviews'|trans|capitalize }}
            </h3>
            <span class="badge bg-secondary rounded-pill fs-6 px-3 py-2">{{ reviews|length }}</span>
        </div>

        {# Formulaire #}
        {% if form %}
            <div class="card review-card mb-4">
                <h5 class="fw-bold mb-3">{{ 'section.leave_review'|trans }}</h5>
                {{ form_start(form) }}

                <div class="mb-3">
                    <label class="form-label fw-medium mb-2">{{ 'form.rating'|trans }}</label>
                    <div class="star-rating d-flex gap-2" id="star-rating" style="font-size:2rem;">
                        {% for i in 1..5 %}
                            <span class="star" data-value="{{ i }}" style="cursor:pointer;color:#ddd;transition:color 0.2s;user-select:none;">
                                ★
                            </span>
                        {% endfor %}
                    </div>
                    {{ form_widget(form.rating) }}
                    {{ form_errors(form.rating) }}
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium mb-2">{{ form.content.vars.label }}</label>
                    {{ form_widget(form.content, {'attr': {'class': 'form-control rounded-4 bg-body', 'rows': '4'}}) }}
                    <small class="text-muted d-block mt-2"><i class="bi bi-info-circle me-1"></i>{{ 'form.helper_password'|trans }}</small>
                    {{ form_errors(form.content) }}
                </div>

                <button class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm py-2">{{ 'button.publish'|trans }}</button>
                {{ form_end(form) }}
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const starRating = document.getElementById('star-rating');
                    if (!starRating) return;

                    const stars = starRating.querySelectorAll('.star');
                    const ratingInput = starRating.closest('form').querySelector('input[type="hidden"]');

                    if (!ratingInput) return;

                    const currentValue = ratingInput.value;
                    if (currentValue) {
                        for (let i = 0; i < parseInt(currentValue); i++) {
                            stars[i].style.color = '#ffc107';
                        }
                    }

                    stars.forEach((star, index) => {
                        star.addEventListener('mouseover', function() {
                            for (let i = 0; i <= index; i++) {
                                stars[i].style.color = '#ffc107';
                            }
                            for (let i = index + 1; i < stars.length; i++) {
                                stars[i].style.color = '#ddd';
                            }
                        });

                        star.addEventListener('mouseout', function() {
                            const currentVal = ratingInput.value;
                            for (let i = 0; i < stars.length; i++) {
                                stars[i].style.color = (i < currentVal) ? '#ffc107' : '#ddd';
                            }
                        });

                        star.addEventListener('click', function() {
                            ratingInput.value = index + 1;
                            for (let i = 0; i <= index; i++) {
                                stars[i].style.color = '#ffc107';
                            }
                            for (let i = index + 1; i < stars.length; i++) {
                                stars[i].style.color = '#ddd';
                            }
                        });
                    });
                });
            </script>
        {% endif %}

        {# Mon avis (si j'en ai un) #}
        {% if userReview %}
            <div class="card review-card mb-4" style="background: var(--bs-primary-bg-subtle);">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h6 class="fw-bold text-primary mb-1">
                            <i class="bi bi-person-fill me-1"></i>{{ 'section.my_review'|trans }}
                        </h6>
                        <small class="text-muted">{{ userReview.createdAt|date('d/m/Y') }}</small>
                    </div>
                    <form method="post" action="{{ path('app_review_delete', {id: userReview.id}) }}"
                          class="d-inline"
                          onsubmit="return confirm('{{ 'message.confirm_delete_review'|trans }}')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-review-' ~ userReview.id) }}">
                        <button class="btn btn-sm btn-outline-danger rounded-circle" title="{{ 'button.delete_review'|trans }}" style="width: 32px; height: 32px; padding: 0;">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
                {% if userReview.author.id in verifiedBuyerIds %}
                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill d-inline-flex align-items-center mb-3" style="width: fit-content;">
                        <i class="bi bi-check-circle-fill me-2"></i>{{ 'info.verified_purchase'|trans }}
                    </span>
                {% endif %}
                <div class="mb-2">
                    {{ include('seller/_stars.html.twig', {rating: userReview.rating}) }}
                </div>
                <p class="mb-0 fs-6 text-body-secondary">{{ userReview.content }}</p>
            </div>
        {% elseif not app.user %}
            <div class="alert alert-secondary border-0 shadow-sm rounded-4 p-4 text-center">
                <i class="bi bi-lock fs-3 text-muted mb-2 d-block"></i>
                <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold">{{ 'message.login_to_review'|trans }}</a>
            </div>
        {% elseif app.user == seller %}
            <div class="alert alert-info border-0 shadow-sm rounded-4 p-4 text-center">
                <i class="bi bi-info-circle fs-3 text-info mb-2 d-block"></i>
                <span class="fw-medium">{{ 'message.cannot_self_rate'|trans }}</span>
            </div>
        {% endif %}

        {# Autres avis #}
        <div>
            <h5 class="fw-bold mb-3 mt-5">{{ 'section.other_reviews'|trans }}</h5>
            {% if reviews|length == 0 %}
                <div class="card review-card bg-transparent border border-dashed text-center p-4">
                    <p class="text-muted mb-0">{{ 'empty.no_reviews'|trans }}</p>
                </div>
            {% else %}
                <div class="d-flex flex-column gap-3">
                    {% for review in reviews %}
                        {% if review != userReview %}
                        <div class="card review-card">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="fw-bold fs-6 d-block mb-1">
                                        <i class="bi bi-person-circle text-muted me-2"></i>
                                        {{ review.author.firstName }} {{ review.author.lastName|first }}.
                                    </span>
                                    {% if review.author.id in verifiedBuyerIds %}
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill" style="font-size:0.7rem;">
                                            <i class="bi bi-check-circle-fill me-1"></i>{{ 'info.verified_purchase'|trans }}
                                        </span>
                                    {% endif %}
                                </div>
                                <span class="text-muted small">{{ review.createdAt|date('d/m/Y') }}</span>
                            </div>
                            <div class="mb-2 mt-1">
                                {{ include('seller/_stars.html.twig', {rating: review.rating}) }}
                            </div>
                            <p class="mb-0 text-body-secondary" style="line-height: 1.6;">{{ review.content }}</p>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
