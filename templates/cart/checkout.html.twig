{% extends 'base.html.twig' %}

{% block title %}Valider la Commande - Bouffay Shop{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="bi bi-credit-card"></i>{{ 'button.checkout'|trans }}</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- Commande Summary -->
            <div class="card mb-4">
                <div class="card-header bg-body-tertiary">
                    <h5 class="mb-0">{{ 'section.order_summary_full'|trans }}</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>{{ 'table.product'|trans }}</th>
                                <th class="text-center">{{ 'table.quantity'|trans }}</th>
                                <th class="text-center">{{ 'table.unit_price'|trans }}</th>
                                <th class="text-right">{{ 'table.subtotal'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in cart.cartItems %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            {% if item.product.images|first %}
                                                <img
                                                    src="{{ asset('uploads/products/' ~ item.product.images|first.filename) }}"
                                                    alt="{{ item.product.name }}"
                                                    class="img-thumbnail me-2"
                                                    style="width: 40px; height: 40px; object-fit: cover;"
                                                >
                                            {% endif %}
                                            <div>
                                                <strong>{{ item.product.name }}</strong><br>
                                                <small class="text-muted">{{ item.product.seller.firstName }}</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">{{ item.quantity }}</td>
                                    <td class="text-center">{{ item.product.price|number_format(2, ',', ' ') }} €</td>
                                    <td class="text-right">
                                        {% set subtotal = item.product.price * item.quantity %}
                                        <strong>{{ subtotal|number_format(2, ',', ' ') }} €</strong>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-body-tertiary">
                    <div class="row">
                        <div class="col-12 d-flex justify-content-end">
                            <strong>{{ 'table.total'|trans }}: {{ total|number_format(2, ',', ' ') }} €</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Address Selection -->
            <div class="card">
                <div class="card-header bg-body-tertiary">
                    <h5 class="mb-0">{{ 'table.shipping_address'|trans }}</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('app_cart_validate') }}" id="orderForm">
                        <input type="hidden" name="_token" value="{{ csrf_token('validate-order') }}">

                        <div class="mb-3">
                            {% if user.addresses|length > 0 %}
                                <label class="form-label">{{ 'select_shipping_address'|trans }}</label>
                                <div class="address-list">
                                    {% for address in user.addresses %}
                                        <div class="form-check mb-3">
                                            <input
                                                class="form-check-input"
                                                type="radio"
                                                name="address_id"
                                                id="address_{{ address.id }}"
                                                value="{{ address.id }}"
                                                {% if loop.first %}checked{% endif %}
                                                required
                                            >
                                            <label class="form-check-label" for="address_{{ address.id }}">
                                                <strong>{{ address.street }}</strong><br>
                                                {{ address.zipCode }} {{ address.city }}, {{ address.country }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="alert alert-warning">
                                    <p>{{ 'empty.no_addresses'|trans }}</p>
                                    <a href="{{ path('app_account', {'_fragment': 'addresses'}) }}" class="btn btn-sm btn-warning">
                                        {{ 'button.add_address'|trans }}
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Summary Sidebar -->
        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-body">
                    <h5 class="card-title mb-4">{{ 'section.recap'|trans }}</h5>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span>{{ 'table.items'|trans }}:</span>
                            <strong>{{ cart.cartItems|length }}</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>{{ 'info.subtotal'|trans }}</span>
                            <strong>{{ total|number_format(2, ',', ' ') }} €</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>{{ 'info.shipping'|trans }}</span>
                            <span>{{ 'info.free_shipping'|trans }}</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between">
                            <span class="h6">{{ 'table.total'|trans }}:</span>
                            <strong class="h6 text-success">{{ total|number_format(2, ',', ' ') }} €</strong>
                        </div>
                    </div>

                    <button
                        type="submit"
                        form="orderForm"
                        class="btn btn-success w-100 mb-2"
                        {% if user.addresses|length == 0 %}disabled{% endif %}
                    >
                        <i class="bi bi-check-circle"></i> {{ 'button.confirm'|trans }}
                    </button>

                    <a href="{{ path('app_cart_show') }}" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left"></i> {{ 'button.back'|trans }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
