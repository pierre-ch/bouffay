<div class="nav-item dropdown me-3">
    <a class="nav-link dropdown-toggle d-flex align-items-center position-relative" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="padding: 0.5rem 0.5rem; border-radius: 50%;" id="notificationDropdown">
        <i class="bi bi-bell fs-5"></i>
        {% if unreadCount > 0 %}
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                {{ unreadCount > 99 ? '99+' : unreadCount }}
                <span class="visually-hidden">notifications non lues</span>
            </span>
        {% endif %}
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="width: 320px; max-height: 400px; overflow-y: auto;">
        <li><h6 class="dropdown-header d-flex justify-content-between align-items-center">
            {{ 'nav.notifications'|trans }}
            {% if unreadCount > 0 %}
                <form action="{{ path('app_notification_read_all') }}" method="POST" class="d-inline" id="readAllForm">
                    <button type="submit" class="btn btn-link btn-sm text-decoration-none p-0">{{ 'button.mark_all_read'|trans }}</button>
                </form>
            {% endif %}
        </h6></li>
        <li><hr class="dropdown-divider"></li>
        
        {% if notifications|length == 0 %}
            <li><span class="dropdown-item text-muted text-center py-3">{{ 'empty.no_notifications'|trans }}</span></li>
        {% else %}
            {% for notification in notifications %}
                <li>
                    <a class="dropdown-item py-2 {{ not notification.isRead ? 'bg-light' : '' }}" href="{{ path('app_notification_read', {id: notification.id}) }}">
                        <div class="d-flex align-items-center mb-1">
                            {% if not notification.isRead %}
                                <span class="spinner-grow spinner-grow-sm text-primary me-2" role="status" aria-hidden="true" style="width: 0.5rem; height: 0.5rem;"></span>
                            {% endif %}
                            <small class="text-muted" style="font-size: 0.75rem;">{{ notification.createdAt|date('d/m/Y H:i') }}</small>
                        </div>
                        <div class="text-wrap" style="font-size: 0.85rem; line-height: 1.3;">
                            {{ notification.messageKey|trans(notification.params) }}
                        </div>
                    </a>
                </li>
            {% endfor %}
            <li><hr class="dropdown-divider"></li>
        {% endif %}
    </ul>
</div>
