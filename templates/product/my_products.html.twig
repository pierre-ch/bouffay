{% extends 'base.html.twig' %}

{% block title %}Mes annonces — Bouffay{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Mes annonces</h1>
    <a href="{{ path('app_product_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvelle annonce
    </a>
</div>

{% if products|length == 0 %}
    <p class="text-muted">Vous n'avez pas encore publié d'annonce.</p>
{% else %}
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Annonce</th>
                    <th>Catégorie</th>
                    <th>Prix</th>
                    <th>Stock</th>
                    <th>Statut</th>
                    <th>Publiée le</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            {% for product in products %}
                <tr>
                    <td>
                        <a href="{{ path('app_product_show', {slug: product.slug}) }}" class="fw-semibold text-decoration-none">
                            {{ product.name }}
                        </a>
                    </td>
                    <td>{{ product.category.name }}</td>
                    <td>{{ product.price }} €</td>
                    <td>{{ product.stock }}</td>
                    <td>
                        {% set badges = {active: 'success', inactive: 'warning', sold: 'secondary'} %}
                        {% set labels = {active: 'En vente', inactive: 'Suspendu', sold: 'Vendu'} %}
                        <span class="badge bg-{{ badges[product.status] ?? 'secondary' }}">
                            {{ labels[product.status] ?? product.status }}
                        </span>
                    </td>
                    <td>{{ product.createdAt|date('d/m/Y') }}</td>
                    <td class="text-end">
                        <a href="{{ path('app_product_edit', {id: product.id}) }}"
                           class="btn btn-sm btn-outline-secondary">Modifier</a>
                        <form method="post"
                              action="{{ path('app_product_delete', {id: product.id}) }}"
                              class="d-inline"
                              onsubmit="return confirm('Supprimer cette annonce ?')">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete-product-' ~ product.id) }}">
                            <button class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
