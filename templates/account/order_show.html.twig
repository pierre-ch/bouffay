{% extends 'base.html.twig' %}

{% block title %}Commande #{{ order.id }} — Bouffay{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-md-3">
        {{ include('account/_sidebar.html.twig') }}
    </div>
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Commande #{{ order.id }}</h1>
            <a href="{{ path('app_account_orders') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Retour
            </a>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-sm-4">
                <div class="card border-0 bg-light text-center p-3">
                    <div class="text-muted small">Date</div>
                    <div class="fw-semibold">{{ order.createdAt|date('d/m/Y') }}</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card border-0 bg-light text-center p-3">
                    <div class="text-muted small">Statut</div>
                    <div class="fw-semibold">{{ order.status }}</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card border-0 bg-light text-center p-3">
                    <div class="text-muted small">Total</div>
                    <div class="fw-semibold">{{ order.totalPrice }} €</div>
                </div>
            </div>
        </div>

        <h5 class="mb-3">Articles commandés</h5>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Produit</th>
                        <th>Quantité</th>
                        <th>Prix unitaire</th>
                        <th>Sous-total</th>
                    </tr>
                </thead>
                <tbody>
                {% for item in order.orderItems %}
                    <tr>
                        <td>{{ item.product.name }}</td>
                        <td>{{ item.quantity }}</td>
                        <td>{{ item.unitPrice }} €</td>
                        <td>{{ (item.quantity * item.unitPrice)|number_format(2, ',', ' ') }} €</td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Total</td>
                        <td class="fw-bold">{{ order.totalPrice }} €</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        {% if order.address %}
        <h5 class="mt-4 mb-2">Adresse de livraison</h5>
        <address class="text-muted">
            {{ order.address.street }}<br>
            {{ order.address.postalCode }} {{ order.address.city }}<br>
            {{ order.address.country }}
        </address>
        {% endif %}
    </div>
</div>
{% endblock %}
