<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom shadow-sm">
    <div class="container">

        {# Logo #}
        <a class="navbar-brand fw-bold fs-4" href="{{ path('app_home') }}">
            <i class="bi bi-shop text-primary"></i> Bouffay
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">

            {# Navigation principale #}
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}"
                       href="{{ path('app_home') }}">{{ 'nav.home'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_product' %}active{% endif %}"
                       href="{{ path('app_product_index') }}">{{ 'nav.products'|trans }}</a>
                </li>

                {# Liens réservés aux vendeurs #}
                {% if is_granted('ROLE_VENDEUR') %}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-grid"></i> {{ 'nav.my_sales'|trans }}
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{{ path('app_product_my') }}">
                            <i class="bi bi-list-ul me-2"></i>{{ 'nav.my_ads'|trans }}
                        </a></li>
                        <li><a class="dropdown-item" href="{{ path('app_seller_sales') }}">
                            <i class="bi bi-bag-check me-2"></i>{{ 'nav.orders_received'|trans }}
                        </a></li>
                        <li><a class="dropdown-item" href="{{ path('app_product_new') }}">
                            <i class="bi bi-plus-circle me-2"></i>{{ 'button.publish_ad'|trans }}
                        </a></li>
                    </ul>
                </li>
                {% endif %}

                {# Liens réservés aux admins #}
                {% if is_granted('ROLE_ADMIN') %}
                <li class="nav-item">
                    <a class="nav-link text-danger" href="{{ path('admin') }}">
                        <i class="bi bi-shield-lock"></i> {{ 'nav.admin'|trans }}
                    </a>
                </li>
                {% endif %}
            </ul>

            {# Actions droite #}
            <ul class="navbar-nav align-items-center gap-1">

                {# Bascule thème clair/sombre #}
                <li class="nav-item">
                    <form method="post" action="{{ path('app_theme_toggle') }}">
                        <button type="submit" class="btn btn-link nav-link px-2" title="Changer de thème">
                            {% if theme == 'dark' %}
                                <i class="bi bi-sun fs-5"></i>
                            {% else %}
                                <i class="bi bi-moon fs-5"></i>
                            {% endif %}
                        </button>
                    </form>
                </li>

                {# Sélecteur de langue #}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        {% if app.request.locale == 'en' %}
                        🇬🇧 EN
                        {% else %}
                        🇫🇷 FR
                        {% endif %}
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{{ path('app_change_locale', {'locale': 'fr'}) }}">
                            🇫🇷 Français
                        </a></li>
                        <li><a class="dropdown-item" href="{{ path('app_change_locale', {'locale': 'en'}) }}">
                            🇬🇧 English
                        </a></li>
                    </ul>
                </li>

                {# Notifications #}
                {% if app.user %}
                    {{ render(controller('App\\Controller\\NotificationController::dropdown')) }}
                {% endif %}

                {# Panier #}
                {% if is_granted('ROLE_CLIENT') %}
                <li class="nav-item">
                    <a class="nav-link position-relative" href="{{ path('app_cart_show') }}" aria-label="{{ 'nav.cart'|trans }}">
                        <i class="bi bi-cart3 fs-5"></i>
                        {% set cartCount = app.user and app.user.cart ? app.user.cart.cartItems|length : 0 %}
                        {% if cartCount > 0 %}
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary">
                            {{ cartCount }}
                        </span>
                        {% endif %}
                    </a>
                </li>
                {% endif %}

                {# Utilisateur connecté #}
                {% if app.user %}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                        {% if app.user.avatar %}
                            <img src="{{ app.user.avatar }}" class="rounded-circle" width="30" height="30" alt="avatar">
                        {% else %}
                            <i class="bi bi-person-circle fs-5"></i>
                        {% endif %}
                        {{ app.user.firstName }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li class="dropdown-header text-muted small">
                            {{ app.user.email }}
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="{{ path('app_account') }}"><i class="bi bi-speedometer2 me-2"></i>{{ 'nav.my_account'|trans }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_account_profile') }}"><i class="bi bi-person me-2"></i>{{ 'nav.my_profile'|trans }}</a></li>
                        {% if is_granted('ROLE_CLIENT') %}
                        <li><a class="dropdown-item" href="{{ path('app_account_orders') }}"><i class="bi bi-bag me-2"></i>{{ 'nav.my_orders'|trans }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_account_favorites') }}"><i class="bi bi-heart me-2"></i>{{ 'nav.my_favorites'|trans }}</a></li>
                        {% endif %}
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                <i class="bi bi-box-arrow-right me-2"></i>{{ 'nav.logout'|trans }}
                            </a>
                        </li>
                    </ul>
                </li>

                {# Utilisateur non connecté #}
                {% else %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_login') }}">{{ 'nav.login'|trans }}</a>
                </li>
                {# <li class="nav-item">
                    <a class="btn btn-primary btn-sm" href="{{ path('app_register') }}">{{ 'nav.register'|trans }}</a>
                </li> #}
                {% endif %}

            </ul>
        </div>
    </div>
</nav>
