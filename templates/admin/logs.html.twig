{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Logs Système ({{ app.environment }}){% endblock %}

{% block main %}
    <div class="card shadow-sm">
        <div class="card-body p-0 bg-dark text-light" style="max-height: 75vh; overflow-y: auto;">
            {% if logs|length > 0 %}
                <table class="table table-dark table-sm table-borderless mb-0" style="font-family: monospace; font-size: 0.85rem;">
                    <tbody>
                        {% for log in logs %}
                            {% set rowClass = '' %}
                            {% if 'ERROR' in log or 'CRITICAL' in log or 'EMERGENCY' in log %}
                                {% set rowClass = 'text-danger fw-bold' %}
                            {% elseif 'WARNING' in log %}
                                {% set rowClass = 'text-warning' %}
                            {% elseif 'INFO' in log %}
                                {% set rowClass = 'text-info' %}
                            {% endif %}
                            <tr>
                                <td class="{{ rowClass }} text-break border-bottom border-secondary">{{ log }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="p-4 text-center text-muted">
                    <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
                    Aucun log disponible pour le moment.
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
