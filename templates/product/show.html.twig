{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} — Bouffay{% endblock %}

{% block body %}
<div class="row g-4">
    {# Images #}
    <div class="col-md-6">
        {% if product.images|length > 0 %}
            <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                 class="img-fluid rounded shadow-sm w-100" style="object-fit:cover;max-height:400px;"
                 alt="{{ product.name }}">
            {% if product.images|length > 1 %}
            <div class="d-flex gap-2 mt-2 flex-wrap">
                {% for image in product.images %}
                    <img src="{{ asset('uploads/products/' ~ image.filename) }}"
                         class="rounded" style="height:70px;object-fit:cover;cursor:pointer;"
                         alt="{{ product.name }}">
                {% endfor %}
            </div>
            {% endif %}
        {% else %}
            <div class="bg-body-tertiary rounded d-flex align-items-center justify-content-center"
                 style="height:400px;">
                <i class="bi bi-image text-muted fs-1"></i>
            </div>
        {% endif %}
    </div>

    {# Infos #}
    <div class="col-md-6">
        <h1>{{ product.name }}</h1>

        <p class="text-muted">
            <i class="bi bi-tag"></i> {{ product.category.name }}
            {% for tag in product.tags %}
                <span class="badge bg-secondary ms-1">{{ tag.name }}</span>
            {% endfor %}
        </p>

        <h2 class="text-primary">{{ product.price }} €</h2>

        <ul class="list-unstyled text-muted small mt-3">
            {% if product.stock is not null %}
                <li><i class="bi bi-box"></i> {{ 'info.stock'|trans }} {{ product.stock }}</li>
            {% endif %}
            {% if product.weight %}
                <li><i class="bi bi-speedometer"></i> {{ 'info.weight'|trans }} {{ product.weight }} kg</li>
            {% endif %}
            {% if product.origin %}
                <li><i class="bi bi-geo-alt"></i> {{ 'info.origin'|trans }} {{ product.origin }}</li>
            {% endif %}
            {% if product.expiresAt %}
                <li><i class="bi bi-calendar"></i> {{ 'info.expires'|trans }} {{ product.expiresAt|date('d/m/Y') }}</li>
            {% endif %}
        </ul>

        {% if product.description %}
            <hr>
            <p>{{ product.description|nl2br }}</p>
        {% endif %}

        <hr>
        <div class="card border-0 bg-body-tertiary mb-3">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="mb-1 text-muted small">{{ 'info.sold_by'|trans }} <a href="{{ path('app_seller_show', {id: product.seller.id}) }}" class="fw-semibold text-decoration-none">{{ product.seller.firstName }} {{ product.seller.lastName }}</a></p>
                    <small class="text-muted">{{ 'published_on_date'|trans }} {{ product.createdAt|date('d/m/Y') }}</small>
                </div>
                {% set rating = product.seller.averageRating ?? 0 %}
                {% set reviewCount = product.seller.reviewsReceived|length %}
                <div class="text-end">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-star-fill text-warning me-1"></i>
                        <span class="fw-bold fs-5">{{ rating|number_format(1, ',', ' ') }}</span>
                        <span class="text-muted small ms-1">/ 5</span>
                    </div>
                    {% if reviewCount > 0 %}
                        <small class="text-muted">({{ reviewCount }} {{ 'info.reviews'|trans }})</small>
                    {% else %}
                        <small class="text-muted fst-italic">{{ 'info.new_seller'|trans }}</small>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if app.user and app.user !== product.seller %}
            {% include 'cart/_add_form.html.twig' %}
            {% set isFav = app.user.favorites|filter(f => f.product.id == product.id)|length > 0 %}
            <form method="post"
                  action="{{ path('app_account_favorite_toggle', {id: product.id}) }}" class="mt-2">
                <input type="hidden" name="_token"
                       value="{{ csrf_token('favorite-' ~ product.id) }}">
                <button class="btn w-100 {% if isFav %}btn-danger{% else %}btn-outline-danger{% endif %}">
                    <i class="bi bi-heart{% if isFav %}-fill{% endif %}"></i>
                    {% if isFav %}{{ 'button.remove_from_favorites'|trans }}{% else %}{{ 'button.add_to_favorites'|trans }}{% endif %}
                </button>
            </form>
        {% endif %}

        {% if app.user == product.seller %}
            <div class="d-flex gap-2">
                <a href="{{ path('app_product_edit', {id: product.id}) }}"
                   class="btn btn-outline-secondary flex-fill">{{ 'button.edit'|trans }}</a>
                <form method="post"
                      action="{{ path('app_product_delete', {id: product.id}) }}"
                      onsubmit="return confirm('{{ 'message.confirm_delete_product'|trans }}')">
                    <input type="hidden" name="_token"
                           value="{{ csrf_token('delete-product-' ~ product.id) }}">
                    <button class="btn btn-outline-danger">{{ 'button.delete'|trans }}</button>
                </form>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
