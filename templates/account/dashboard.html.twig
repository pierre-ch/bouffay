{% extends 'base.html.twig' %}

{% block title %}Mon compte — Bouffay{% endblock %}

{% block body %}
<div class="row g-4">

    {# Sidebar #}
    <div class="col-md-3">
        {{ include('account/_sidebar.html.twig') }}
    </div>

    {# Contenu #}
    <div class="col-md-9">
        <h1 class="mb-4">Bonjour, {{ app.user.firstName }} 👋</h1>

        <div class="row g-3 mb-4">
            <div class="col-sm-4">
                <a href="{{ path('app_account_orders') }}" class="text-decoration-none">
                    <div class="card text-center h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-bag fs-2 text-primary"></i>
                            <div class="fw-semibold mt-2">{{ app.user.orders|length }}</div>
                            <div class="text-muted small">Commandes</div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-sm-4">
                <a href="{{ path('app_account_favorites') }}" class="text-decoration-none">
                    <div class="card text-center h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-heart fs-2 text-danger"></i>
                            <div class="fw-semibold mt-2">{{ favoritesCount }}</div>
                            <div class="text-muted small">Favoris</div>
                        </div>
                    </div>
                </a>
            </div>
            {% if is_granted('ROLE_VENDEUR') %}
            <div class="col-sm-4">
                <a href="{{ path('app_product_my') }}" class="text-decoration-none">
                    <div class="card text-center h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <i class="bi bi-tag fs-2 text-success"></i>
                            <div class="fw-semibold mt-2">{{ app.user.products|length }}</div>
                            <div class="text-muted small">Annonces</div>
                        </div>
                    </div>
                </a>
            </div>
            {% endif %}
        </div>

        {# Dernières commandes #}
        <h5 class="mb-3">Dernières commandes</h5>
        {% if recentOrders|length == 0 %}
            <p class="text-muted">Aucune commande pour le moment.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Statut</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for order in recentOrders %}
                        <tr>
                            <td>{{ order.id }}</td>
                            <td>{{ order.createdAt|date('d/m/Y') }}</td>
                            <td>{{ order.totalPrice }} €</td>
                            <td><span class="badge bg-secondary">{{ order.status }}</span></td>
                            <td>
                                <a href="{{ path('app_account_order_show', {id: order.id}) }}"
                                   class="btn btn-sm btn-outline-primary">Détail</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <a href="{{ path('app_account_orders') }}" class="btn btn-outline-secondary btn-sm">
                Toutes les commandes
            </a>
        {% endif %}
    </div>

</div>
{% endblock %}
