{% extends 'base.html.twig' %}

{% block title %}{{ 'title.products'|trans }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>{{ 'nav.products'|trans }}</h1>
    {% if is_granted('ROLE_VENDEUR') %}
        <a href="{{ path('app_product_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> {{ 'button.new_product'|trans }}
        </a>
    {% endif %}
</div>

{% if products|length == 0 %}
    <p class="text-muted">{{ 'empty.no_products'|trans }}</p>
{% else %}
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
        <div class="col">
            <div class="card h-100 shadow-sm">
                {% if product.images|length > 0 %}
                    <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                         class="card-img-top" style="height:200px;object-fit:cover;"
                         alt="{{ product.name }}">
                {% else %}
                    <div class="bg-light d-flex align-items-center justify-content-center"
                         style="height:200px;">
                        <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                {% endif %}
                <div class="card-body">
                    <h5 class="card-title">{{ product.name }}</h5>
                    <p class="card-text text-muted small">
                        {{ product.category.name }}
                        {% if product.tags|length > 0 %}
                            &bull;
                            {% for tag in product.tags %}
                                <span class="badge bg-secondary">{{ tag.name }}</span>
                            {% endfor %}
                        {% endif %}
                    </p>
                    <p class="card-text fw-bold fs-5">{{ product.price }} {{ 'format.currency'|trans }}</p>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center gap-2">
                    <small class="text-muted">{{ product.seller.firstName }}</small>
                    {% if app.user and app.user !== product.seller %}
                    <form method="POST" action="{{ path('app_cart_add', {productId: product.id}) }}" class="d-inline">
                        <input type="hidden" name="quantity" value="1">
                        <button type="submit" class="btn btn-sm btn-primary" title="{{ 'button.add_to_cart'|trans }}">
                            <i class="bi bi-bag-plus"></i>
                        </button>
                    </form>
                    {% endif %}
                    <a href="{{ path('app_product_show', {slug: product.slug}) }}"
                       class="btn btn-sm btn-outline-primary">{{ 'button.view'|trans }}</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

