{% extends 'base.html.twig' %}

{% block title %}{{ seller.firstName }} {{ seller.lastName }} — Bouffay{% endblock %}

{% block body %}

{# En-tête vendeur #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body d-flex align-items-center gap-4 p-4">
        {% if seller.avatar %}
            <img src="{{ seller.avatar }}" class="rounded-circle" width="80" height="80" alt="avatar">
        {% else %}
            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fs-2"
                 style="width:80px;height:80px;">
                {{ seller.firstName|first|upper }}
            </div>
        {% endif %}
        <div>
            <h1 class="mb-1">{{ seller.firstName }} {{ seller.lastName }}</h1>
            <p class="text-muted mb-1 small">
                <i class="bi bi-calendar me-1"></i>{{ 'info.member_since'|trans }} {{ seller.createdAt|date('F Y') }}
            </p>
            <div class="d-flex align-items-center gap-2">
                {{ include('seller/_stars.html.twig', {rating: averageRating}) }}
                {% if averageRating %}
                    <span class="fw-semibold">{{ averageRating }}/5</span>
                    <span class="text-muted small">({{ reviews|length }} avis)</span>
                {% else %}
                    <span class="text-muted small">{{ 'empty.no_reviews'|trans }}</span>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    {# Annonces du vendeur #}
    <div class="col-lg-8">
        <h4 class="mb-3">
            Annonces <span class="badge bg-secondary">{{ products|length }}</span>
        </h4>

        {% if products|length == 0 %}
            <p class="text-muted">{{ 'empty.no_seller_products'|trans }}</p>
        {% else %}
            <div class="row row-cols-1 row-cols-md-2 g-3">
                {% for product in products %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        {% if product.images|length > 0 %}
                            <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                                 class="card-img-top" style="height:150px;object-fit:cover;">
                        {% endif %}
                        <div class="card-body">
                            <h6 class="card-title">{{ product.name }}</h6>
                            <p class="text-primary fw-semibold mb-0">{{ product.price }} €</p>
                        </div>
                        <div class="card-footer">
                            <a href="{{ path('app_product_show', {slug: product.slug}) }}"
                               class="btn btn-sm btn-outline-primary w-100">{{ 'button.view'|trans }}</a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Avis #}
    <div class="col-lg-4">
        <h4 class="mb-3">
            Avis <span class="badge bg-secondary">{{ reviews|length }}</span>
        </h4>

        {# Formulaire #}
        {% if form %}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-3">
                    <h6 class="mb-3">{{ 'section.leave_review'|trans }}</h6>
                    {{ form_start(form) }}

                    <div class="mb-3">
                        <label class="form-label mb-2">{{ 'form.rating'|trans }}</label>
                        <div class="star-rating d-flex gap-2" id="star-rating" style="font-size:2rem;">
                            {% for i in 1..5 %}
                                <span class="star" data-value="{{ i }}" style="cursor:pointer;color:#ddd;transition:color 0.2s;user-select:none;">
                                    ★
                                </span>
                            {% endfor %}
                        </div>
                        {{ form_widget(form.rating) }}
                        {{ form_errors(form.rating) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.content) }}
                        {{ form_widget(form.content, {'attr': {'class': 'form-control'}}) }}
                        <small class="text-muted d-block mt-1">{{ 'form.helper_password'|trans }}</small>
                        {{ form_errors(form.content) }}
                    </div>

                    <button class="btn btn-primary w-100 btn-sm">{{ 'button.publish'|trans }}</button>
                    {{ form_end(form) }}
                </div>
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const starRating = document.getElementById('star-rating');
                    if (!starRating) return;

                    const stars = starRating.querySelectorAll('.star');
                    const ratingInput = starRating.closest('form').querySelector('input[type="hidden"]');

                    if (!ratingInput) return;

                    const currentValue = ratingInput.value;
                    if (currentValue) {
                        for (let i = 0; i < parseInt(currentValue); i++) {
                            stars[i].style.color = '#ffc107';
                        }
                    }

                    stars.forEach((star, index) => {
                        star.addEventListener('mouseover', function() {
                            for (let i = 0; i <= index; i++) {
                                stars[i].style.color = '#ffc107';
                            }
                            for (let i = index + 1; i < stars.length; i++) {
                                stars[i].style.color = '#ddd';
                            }
                        });

                        star.addEventListener('mouseout', function() {
                            const currentVal = ratingInput.value;
                            for (let i = 0; i < stars.length; i++) {
                                stars[i].style.color = (i < currentVal) ? '#ffc107' : '#ddd';
                            }
                        });

                        star.addEventListener('click', function() {
                            ratingInput.value = index + 1;
                            for (let i = 0; i <= index; i++) {
                                stars[i].style.color = '#ffc107';
                            }
                            for (let i = index + 1; i < stars.length; i++) {
                                stars[i].style.color = '#ddd';
                            }
                        });
                    });
                });
            </script>
        {% endif %}

        {# Mon avis (si j'en ai un) #}
        {% if userReview %}
            <div class="card border-2 border-primary shadow-sm mb-4 bg-body-tertiary">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="mb-0">
                                {{ 'section.my_review'|trans }}
                                {% if userReview.author.id in verifiedBuyerIds %}
                                    <span class="badge bg-success rounded-pill ms-2" style="font-size:0.65rem;" title="{{ 'info.verified_purchase'|trans }}">
                                        <i class="bi bi-check-circle me-1"></i>{{ 'info.verified_purchase'|trans }}
                                    </span>
                                {% endif %}
                            </h6>
                            <small class="text-muted">{{ userReview.createdAt|date('d/m/Y') }}</small>
                        </div>
                        <form method="post" action="{{ path('app_review_delete', {id: userReview.id}) }}"
                              class="d-inline"
                              onsubmit="return confirm('Supprimer votre avis ?')">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete-review-' ~ userReview.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                    {{ include('seller/_stars.html.twig', {rating: userReview.rating}) }}
                    <p class="mb-0 mt-2 small">{{ userReview.content }}</p>
                </div>
            </div>
        {% elseif not app.user %}
            <div class="alert alert-secondary small">
                <a href="{{ path('app_login') }}">{{ 'message.login_to_review'|trans }}
            </div>
        {% elseif app.user == seller %}
            <div class="alert alert-info small">
                <i class="bi bi-info-circle me-1"></i>{{ 'message.cannot_self_rate'|trans }}
            </div>
        {% endif %}

        {# Autres avis #}
        <div>
            <h6 class="mb-2">{{ 'section.other_reviews'|trans }}</h6>
            {% if reviews|length == 0 %}
                <p class="text-muted small">{{ 'empty.no_reviews'|trans }}</p>
            {% else %}
                <div class="d-flex flex-column gap-2">
                    {% for review in reviews %}
                        {% if review != userReview %}
                        <div class="card border-0 bg-body-tertiary">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <div>
                                        <span class="fw-semibold small">
                                            {{ review.author.firstName }} {{ review.author.lastName|first }}.
                                        </span>
                                        {% if review.author.id in verifiedBuyerIds %}
                                            <span class="badge bg-success rounded-pill ms-1" style="font-size:0.6rem;" title="{{ 'info.verified_purchase'|trans }}">
                                                <i class="bi bi-check-circle me-1"></i>{{ 'info.verified_purchase'|trans }}
                                            </span>
                                        {% endif %}
                                    </div>
                                    <span class="text-muted small">{{ review.createdAt|date('d/m/Y') }}</span>
                                </div>
                                <div class="mb-1">
                                    {{ include('seller/_stars.html.twig', {rating: review.rating}) }}
                                </div>
                                <p class="mb-0 small">{{ review.content }}</p>
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
