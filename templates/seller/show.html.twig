{% extends 'base.html.twig' %}

{% block title %}{{ seller.firstName }} {{ seller.lastName }} — Bouffay{% endblock %}

{% block body %}

{# En-tête vendeur #}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body d-flex align-items-center gap-4 p-4">
        {% if seller.avatar %}
            <img src="{{ seller.avatar }}" class="rounded-circle" width="80" height="80" alt="avatar">
        {% else %}
            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fs-2"
                 style="width:80px;height:80px;">
                {{ seller.firstName|first|upper }}
            </div>
        {% endif %}
        <div>
            <h1 class="mb-1">{{ seller.firstName }} {{ seller.lastName }}</h1>
            <p class="text-muted mb-1 small">
                <i class="bi bi-calendar me-1"></i>Membre depuis {{ seller.createdAt|date('F Y') }}
            </p>
            <div class="d-flex align-items-center gap-2">
                {{ include('seller/_stars.html.twig', {rating: averageRating}) }}
                {% if averageRating %}
                    <span class="fw-semibold">{{ averageRating }}/5</span>
                    <span class="text-muted small">({{ reviews|length }} avis)</span>
                {% else %}
                    <span class="text-muted small">Aucun avis pour le moment</span>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    {# Annonces du vendeur #}
    <div class="col-lg-8">
        <h4 class="mb-3">
            Annonces <span class="badge bg-secondary">{{ products|length }}</span>
        </h4>

        {% if products|length == 0 %}
            <p class="text-muted">Ce vendeur n'a aucune annonce active.</p>
        {% else %}
            <div class="row row-cols-1 row-cols-md-2 g-3">
                {% for product in products %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        {% if product.images|length > 0 %}
                            <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                                 class="card-img-top" style="height:150px;object-fit:cover;">
                        {% endif %}
                        <div class="card-body">
                            <h6 class="card-title">{{ product.name }}</h6>
                            <p class="text-primary fw-semibold mb-0">{{ product.price }} €</p>
                        </div>
                        <div class="card-footer">
                            <a href="{{ path('app_product_show', {slug: product.slug}) }}"
                               class="btn btn-sm btn-outline-primary w-100">Voir l'annonce</a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Avis #}
    <div class="col-lg-4">
        <h4 class="mb-3">
            Avis <span class="badge bg-secondary">{{ reviews|length }}</span>
        </h4>

        {# Formulaire #}
        {% if form %}
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body p-3">
                    <h6 class="mb-3">Laisser un avis</h6>
                    {{ form_start(form) }}

                    <div class="mb-2">
                        {{ form_label(form.rating) }}
                        <div class="d-flex gap-3 flex-wrap">
                            {% for child in form.rating %}
                                <div class="form-check">
                                    {{ form_widget(child) }}
                                    {{ form_label(child) }}
                                </div>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.rating) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.content) }}
                        {{ form_widget(form.content, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.content) }}
                    </div>

                    <button class="btn btn-primary w-100 btn-sm">Publier mon avis</button>
                    {{ form_end(form) }}
                </div>
            </div>
        {% elseif alreadyReviewed %}
            <div class="alert alert-info small">Vous avez déjà laissé un avis sur ce vendeur.</div>
        {% elseif not app.user %}
            <div class="alert alert-secondary small">
                <a href="{{ path('app_login') }}">Connectez-vous</a> pour laisser un avis.
            </div>
        {% endif %}

        {# Liste des avis #}
        {% if reviews|length == 0 %}
            <p class="text-muted small">Aucun avis pour le moment.</p>
        {% else %}
            <div class="d-flex flex-column gap-3">
                {% for review in reviews %}
                <div class="card border-0 bg-light">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <span class="fw-semibold small">
                                {{ review.author.firstName }} {{ review.author.lastName|first }}.
                            </span>
                            <span class="text-muted small">{{ review.createdAt|date('d/m/Y') }}</span>
                        </div>
                        {{ include('seller/_stars.html.twig', {rating: review.rating}) }}
                        <p class="mb-0 mt-2 small">{{ review.content }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
