{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ product.name }}{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-md-3">
        {{ include('seller/_sidebar.html.twig') }}
    </div>
    <div class="col-md-9">
        <h1 class="mb-4">{{ 'title.edit_product'|trans }}</h1>

        {% if product.images|length > 0 %}
        <div class="mb-3 d-flex gap-2 flex-wrap">
            {% for image in product.images %}
                <img src="{{ asset('uploads/products/' ~ image.filename) }}"
                     class="rounded" style="height:80px;object-fit:cover;">
            {% endfor %}
        </div>
        {% endif %}

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                {{ include('product/_form.html.twig', {button_label: 'Enregistrer les modifications'}) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
