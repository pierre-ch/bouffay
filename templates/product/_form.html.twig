{{ form_start(form) }}

<div class="mb-3">
    {{ form_label(form.name) }}
    {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.name) }}
</div>

<div class="mb-3">
    {{ form_label(form.description) }}
    {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.description) }}
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        {{ form_label(form.price) }}
        {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.price) }}
    </div>
    <div class="col-md-4 mb-3">
        {{ form_label(form.stock) }}
        {{ form_widget(form.stock, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.stock) }}
    </div>
    <div class="col-md-4 mb-3">
        {{ form_label(form.status) }}
        {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.status) }}
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        {{ form_label(form.weight) }}
        {{ form_widget(form.weight, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.weight) }}
    </div>
    <div class="col-md-4 mb-3">
        {{ form_label(form.origin) }}
        {{ form_widget(form.origin, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.origin) }}
    </div>
    <div class="col-md-4 mb-3">
        {{ form_label(form.expiresAt) }}
        {{ form_widget(form.expiresAt, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.expiresAt) }}
    </div>
</div>

<div class="mb-3">
    {{ form_label(form.category) }}
    {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
    {{ form_errors(form.category) }}
</div>

<div class="mb-3">
    {{ form_label(form.tags) }}
    {{ form_widget(form.tags, {'attr': {'class': 'form-select'}}) }}
    <div class="form-text">Maintenez Ctrl (ou Cmd) pour sélectionner plusieurs tags.</div>
    {{ form_errors(form.tags) }}
</div>

<div class="mb-3">
    {{ form_label(form.imageFiles) }}
    {{ form_widget(form.imageFiles, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.imageFiles) }}
    <div class="form-text">JPG, PNG ou WebP, 2 Mo max par image.</div>
</div>

<button type="submit" class="btn btn-primary">{{ button_label ?? 'Enregistrer' }}</button>

{{ form_end(form) }}
