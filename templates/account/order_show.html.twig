{% extends 'base.html.twig' %}

{% block title %}{{ 'title.order_show'|trans }} #{{ order.id }} — Bouffay{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-md-3">
        {{ include('account/_sidebar.html.twig') }}
    </div>
    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>{{ 'title.order_show'|trans }} #{{ order.id }}</h1>
            <a href="{{ path('app_account_orders') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>{{ "button.back"|trans }}
            </a>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-sm-4">
                <div class="card border-0 bg-body-tertiary text-center p-3">
                    <div class="text-muted small">{{ 'table.date'|trans }}</div>
                    <div class="fw-semibold">{{ order.createdAt|date('d/m/Y') }}</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card border-0 bg-body-tertiary text-center p-3">
                    <div class="text-muted small">{{ 'table.status'|trans }}</div>
                    <div class="fw-semibold">{{ ('status.' ~ order.globalStatus)|trans }}</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card border-0 bg-body-tertiary text-center p-3">
                    <div class="text-muted small">{{ 'table.total'|trans }}</div>
                    <div class="fw-semibold">{{ order.totalPrice }} {{ 'format.currency'|trans }}</div>
                </div>
            </div>
        </div>

        {% set itemsBySeller = {} %}
        {% for item in order.orderItems %}
            {% set sellerName = item.product.seller.firstName ~ ' ' ~ item.product.seller.lastName %}
            {% if itemsBySeller[sellerName] is not defined %}
                {% set itemsBySeller = itemsBySeller|merge({(sellerName): []}) %}
            {% endif %}
            {% set itemsBySeller = itemsBySeller|merge({(sellerName): itemsBySeller[sellerName]|merge([item])}) %}
        {% endfor %}

        {% set badges = {pending: 'warning', paid: 'info', shipped: 'primary', delivered: 'success', cancelled: 'danger'} %}

        {% for sellerName, items in itemsBySeller %}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-body d-flex justify-content-between align-items-center py-3">
                    <h6 class="mb-0 text-primary"><i class="bi bi-box-seam me-2"></i>{{ 'section.package_from'|trans }} {{ sellerName }}</h6>
                    <span class="badge bg-{{ badges[items[0].status] ?? 'secondary' }}">
                        {{ ('status.' ~ items[0].status)|trans }}
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr class="table-light">
                                <th>{{ 'table.product'|trans }}</th>
                                <th>{{ 'table.quantity'|trans }}</th>
                                <th>{{ 'table.unit_price'|trans }}</th>
                                <th>{{ 'table.subtotal'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% set sellerSubtotal = 0 %}
                        {% for item in items %}
                            {% set subtotal = item.quantity * item.unitPrice %}
                            {% set sellerSubtotal = sellerSubtotal + subtotal %}
                            <tr>
                                <td>{{ item.product.name }}</td>
                                <td>{{ item.quantity }}</td>
                                <td>{{ item.unitPrice }} {{ 'format.currency'|trans }}</td>
                                <td>{{ subtotal|number_format(2, ',', ' ') }} {{ 'format.currency'|trans }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if items[0].statusHistories|length > 0 %}
                <div class="card-footer bg-body border-0 pt-3 pb-3">
                    <h6 class="text-muted small text-uppercase mb-3"><i class="bi bi-clock-history me-1"></i>{{ 'section.status_history'|trans }}</h6>
                    <ul class="list-unstyled mb-0 ms-2" style="border-left: 2px solid #dee2e6; padding-left: 1.5rem; position: relative;">
                        {% for history in items[0].statusHistories %}
                            <li class="mb-2 position-relative">
                                <span class="position-absolute bg-secondary rounded-circle" style="width: 8px; height: 8px; left: -1.75rem; top: 0.35rem;"></span>
                                <span class="fw-semibold small me-2">{{ ('status.' ~ history.status)|trans }}</span>
                                <span class="text-muted small">{{ history.createdAt|date('d/m/Y H:i') }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
                {% endif %}
            </div>
        {% endfor %}

        <div class="text-end mb-4">
            <h4 class="fw-bold">{{ 'table.total'|trans }} : {{ order.totalPrice }} {{ 'format.currency'|trans }}</h4>
        </div>

        {% if order.address %}
        <h5 class="mt-4 mb-2">{{ 'table.shipping_address'|trans }}</h5>
        <address class="text-muted">
            {{ order.address.street }}<br>
            {{ order.address.zipCode }} {{ order.address.city }}<br>
            {{ order.address.country }}
        </address>
        {% endif %}
    </div>
</div>
{% endblock %}
