{% extends 'base.html.twig' %}

{% block title %}{{ 'title.login'|trans }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm mt-4">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">{{ 'nav.login'|trans }}</h2>

                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label for="email" class="form-label">{{ 'form.email'|trans }}</label>
                        <input type="email" id="email" name="_username" class="form-control"
                               value="{{ last_username }}" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">{{ 'form.password'|trans }}</label>
                        <input type="password" id="password" name="_password" class="form-control" required>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" id="remember" name="_remember_me" class="form-check-input">
                        <label for="remember" class="form-check-label">{{ 'form.remember_me'|trans }}</label>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn btn-primary w-100">{{ 'button.login'|trans }}</button>
                </form>

                {# <div class="text-center mt-3">
                    <a href="{{ path('app_register') }}">{{ 'message.no_account'|trans }}</a>
                </div> #}
            </div>
        </div>
    </div>
</div>
{% endblock %}

