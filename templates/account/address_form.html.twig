{% extends 'base.html.twig' %}

{% block title %}{{ title|trans }} - Bouffay Shop{% endblock %}

{% block body %}
<div class="row g-4">
    <div class="col-md-3">
        {% include 'account/_sidebar.html.twig' %}
    </div>

    <div class="col-md-9">
        <h1 class="mb-4">{{ title|trans }}</h1>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.street) }}
                    {{ form_widget(form.street, {'attr': {'class': 'form-control', 'placeholder': '123 Rue de la Paix'}}) }}
                    {{ form_errors(form.street) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.city) }}
                        {{ form_widget(form.city, {'attr': {'class': 'form-control', 'placeholder': 'Paris'}}) }}
                        {{ form_errors(form.city) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.zipCode) }}
                        {{ form_widget(form.zipCode, {'attr': {'class': 'form-control', 'placeholder': '75001'}}) }}
                        {{ form_errors(form.zipCode) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.country) }}
                    {{ form_widget(form.country, {'attr': {'class': 'form-control', 'placeholder': 'France'}}) }}
                    {{ form_errors(form.country) }}
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        {{ form_widget(form.isDefault, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.isDefault, 'form.use_as_default'|trans, {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i>{{ 'button.save'|trans }}</button>
                    <a href="{{ path('app_account_addresses') }}" class="btn btn-outline-secondary">
                        {{ 'button.cancel'|trans }}
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
