{% extends 'base.html.twig' %}

{% block title %}{{ 'title.products'|trans }}{% endblock %}

{% block body %}
<style>
.product-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 1.5rem;
    border: none;
}
.product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 1rem 3rem rgba(0,0,0,0.15) !important;
}
.tag-badge {
    background: var(--bs-primary-bg-subtle);
    color: var(--bs-primary);
    padding: 0.3rem 0.8rem;
    border-radius: 1rem;
    font-size: 0.85rem;
    font-weight: 500;
}
.search-container {
    background: var(--bs-body-tertiary);
    border-radius: 1.5rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: none;
    box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.05);
}
.filter-card {
    border-radius: 1.5rem;
    background: var(--bs-body-bg);
    border: 1px solid var(--bs-border-color-translucent);
}
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6 fw-bold mb-0">{{ 'nav.products'|trans }}</h1>
    {% if is_granted('ROLE_VENDEUR') %}
        <a href="{{ path('app_product_new') }}" class="btn btn-primary rounded-pill shadow-sm px-4 fw-bold">
            <i class="bi bi-plus-lg me-2"></i> {{ 'button.new_product'|trans }}
        </a>
    {% endif %}
</div>

{# Barre de recherche et filtres #}
<div class="search-container">
    {{ form_start(searchForm) }}
    <div class="d-flex flex-wrap gap-3 mb-3">
        <div class="flex-grow-1">
            <div class="input-group">
                <span class="input-group-text bg-body border-end-0 rounded-start-pill ps-4">
                    <i class="bi bi-search text-muted"></i>
                </span>
                {{ form_widget(searchForm.name, {attr: {class: 'form-control border-start-0 rounded-end-pill py-2', placeholder: 'form.search.placeholder_long'|trans}}) }}
            </div>
        </div>
        <div class="d-flex gap-2">
            {{ form_widget(searchForm.sort, {attr: {class: 'form-select rounded-pill py-2 w-auto'}}) }}
            <button type="button" class="btn btn-outline-secondary rounded-pill px-4"
                    data-bs-toggle="collapse" data-bs-target="#filtresAvances"
                    aria-expanded="false">
                <i class="bi bi-sliders me-2"></i> {{ 'button.filters'|trans }}
            </button>
            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
                {{ 'button.search'|trans }}
            </button>
            <a href="{{ path('app_product_index') }}" class="btn btn-outline-danger rounded-circle d-flex align-items-center justify-content-center" title="{{ 'button.reset'|trans }}" style="width: 42px; height: 42px; padding: 0;">
                <i class="bi bi-arrow-counterclockwise"></i>
            </a>
        </div>
    </div>

    {# Filtres avancés rétractables #}
    <div class="collapse" id="filtresAvances">
        <div class="card card-body filter-card shadow-sm mt-3">
            <div class="row g-4">
                <div class="col-md-3">
                    {{ form_label(searchForm.category, null, {label_attr: {class: 'form-label fw-semibold text-muted mb-2'}}) }}
                    {{ form_widget(searchForm.category, {attr: {class: 'form-select rounded-3'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(searchForm.minPrice, null, {label_attr: {class: 'form-label fw-semibold text-muted mb-2'}}) }}
                    {{ form_widget(searchForm.minPrice, {attr: {class: 'form-control rounded-3', placeholder: 'Min'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(searchForm.maxPrice, null, {label_attr: {class: 'form-label fw-semibold text-muted mb-2'}}) }}
                    {{ form_widget(searchForm.maxPrice, {attr: {class: 'form-control rounded-3', placeholder: 'Max'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(searchForm.expiresAtAfter, null, {label_attr: {class: 'form-label fw-semibold text-muted mb-2'}}) }}
                    {{ form_widget(searchForm.expiresAtAfter, {attr: {class: 'form-control rounded-3'}}) }}
                </div>
                <div class="col-md-2">
                    {{ form_label(searchForm.expiresAtBefore, null, {label_attr: {class: 'form-label fw-semibold text-muted mb-2'}}) }}
                    {{ form_widget(searchForm.expiresAtBefore, {attr: {class: 'form-control rounded-3'}}) }}
                </div>
            </div>
            <div class="mt-4 pt-3 border-top">
                <p class="fw-semibold text-muted mb-3">{{ 'form.tags'|trans }}</p>
                <div class="d-flex flex-wrap gap-2">
                    {% for checkbox in searchForm.tags %}
                        <div>
                            {{ form_widget(checkbox, {attr: {class: 'btn-check'}}) }}
                            <label class="btn btn-outline-secondary btn-sm rounded-pill px-3 py-1" for="{{ checkbox.vars.id }}">
                                {{ checkbox.vars.label }}
                            </label>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
    {{ form_end(searchForm) }}
</div>

{# Résultats #}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-muted fs-5">{{ products|length }} {{ 'info.ads_found'|trans }}</h3>
</div>

{% if products|length == 0 %}
    <div class="alert alert-light border-0 shadow-sm rounded-4 text-center p-5">
        <i class="bi bi-search fs-1 text-muted mb-3 d-block"></i>
        <p class="text-muted fs-5 mb-0">{{ 'empty.no_products'|trans }}</p>
    </div>
{% else %}
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 mb-5">
        {% for product in products %}
        <div class="col">
            <div class="card h-100 shadow-sm product-card overflow-hidden">
                <div class="position-relative">
                    {% if product.images|length > 0 %}
                        <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                             class="card-img-top" style="height:220px;object-fit:cover;"
                             alt="{{ product.name }}">
                    {% else %}
                        <div class="bg-body-tertiary d-flex align-items-center justify-content-center"
                             style="height:220px;">
                            <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                        </div>
                    {% endif %}
                    <div class="position-absolute top-0 end-0 p-3">
                        <span class="badge bg-dark bg-opacity-75 rounded-pill fs-6 px-3 py-2 shadow" style="backdrop-filter: blur(5px);">
                            {{ product.price }} {{ 'format.currency'|trans }}
                        </span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-3 text-truncate" title="{{ product.name }}">{{ product.name }}</h5>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="tag-badge">
                            <i class="bi bi-tag-fill me-1"></i> {{ product.category.name }}
                        </span>
                        {% for tag in product.tags|slice(0, 2) %}
                            <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">{{ tag.name }}</span>
                        {% endfor %}
                        {% if product.tags|length > 2 %}
                            <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">+{{ product.tags|length - 2 }}</span>
                        {% endif %}
                    </div>
                    <div class="d-flex align-items-center gap-2 mt-auto">
                        <i class="bi bi-person-circle text-muted"></i>
                        <small class="text-muted">{{ product.seller.firstName }}</small>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0 pb-4 px-4 pt-0 d-flex gap-2">
                    <a href="{{ path('app_product_show', {slug: product.slug}) }}"
                       class="btn btn-outline-primary rounded-pill flex-grow-1 fw-bold">{{ 'button.view'|trans }}</a>
                       
                    {% if app.user and app.user !== product.seller %}
                    <form method="POST" action="{{ path('app_cart_add', {productId: product.id}) }}" class="d-inline">
                        <input type="hidden" name="quantity" value="1">
                        <input type="hidden" name="_token" value="{{ csrf_token('add_to_cart') }}">
                        <button type="submit" class="btn btn-primary rounded-pill d-flex align-items-center justify-content-center" style="width: 42px; padding: 0;" title="{{ 'button.add_to_cart'|trans }}">
                            <i class="bi bi-bag-plus fs-5"></i>
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

