{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} — Bouffay{% endblock %}

{% block body %}
<style>
.product-image-main {
    border-radius: 1.5rem;
    box-shadow: 0 1rem 3rem rgba(0,0,0,0.1);
    object-fit: cover;
    max-height: 450px;
    width: 100%;
}
.product-thumbnail {
    border-radius: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    height: 80px;
    width: 80px;
    object-fit: cover;
    cursor: pointer;
}
.product-thumbnail:hover {
    transform: translateY(-5px);
    box-shadow: 0 .5rem 1.5rem rgba(0,0,0,0.15);
}
.price-badge {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 2rem;
    display: inline-block;
    box-shadow: 0 8px 20px rgba(0, 242, 254, 0.3);
}
.seller-card {
    border-radius: 1.5rem;
    background: var(--bs-body-tertiary);
    border: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.seller-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.05);
}
.action-btn {
    border-radius: 2rem;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.action-btn:hover {
    transform: translateY(-2px);
}
.tag-badge {
    background: var(--bs-primary-bg-subtle);
    color: var(--bs-primary);
    padding: 0.4rem 0.8rem;
    border-radius: 1rem;
    font-weight: 500;
}
input[type=number]::-webkit-inner-spin-button, 
input[type=number]::-webkit-outer-spin-button { 
  -webkit-appearance: none; 
  margin: 0; 
}
</style>

<div class="row g-5 align-items-start mt-2">
    {# Images #}
    <div class="col-md-6">
        {% if product.images|length > 0 %}
            <div class="position-relative">
                <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}"
                     class="product-image-main"
                     alt="{{ product.name }}">
            </div>
            {% if product.images|length > 1 %}
            <div class="d-flex gap-3 mt-4 flex-wrap">
                {% for image in product.images %}
                    <img src="{{ asset('uploads/products/' ~ image.filename) }}"
                         class="product-thumbnail"
                         alt="{{ product.name }}">
                {% endfor %}
            </div>
            {% endif %}
        {% else %}
            <div class="bg-body-tertiary d-flex align-items-center justify-content-center"
                 style="height:450px; border-radius: 1.5rem; box-shadow: 0 1rem 3rem rgba(0,0,0,0.05);">
                <i class="bi bi-image text-muted" style="font-size: 5rem;"></i>
            </div>
        {% endif %}
    </div>

    {# Infos #}
    <div class="col-md-6">
        <h1 class="display-6 fw-bolder mb-3">{{ product.name }}</h1>

        <div class="d-flex flex-wrap gap-2 mb-4 align-items-center">
            <span class="tag-badge">
                <i class="bi bi-tag-fill me-1"></i> {{ product.category.name }}
            </span>
            {% for tag in product.tags %}
                <span class="badge bg-secondary rounded-pill px-3 py-2">{{ tag.name }}</span>
            {% endfor %}
        </div>

        <h2 class="price-badge fs-3 fw-bold mb-4">{{ product.price }} {{ 'format.currency'|trans }}</h2>

        <div class="card border-0 bg-body-tertiary rounded-4 p-4 mb-4">
            <ul class="list-unstyled mb-0 d-flex flex-column gap-3 text-body-secondary fw-medium">
                {% if product.stock is not null %}
                    <li class="d-flex align-items-center gap-3">
                        <i class="bi bi-box-seam fs-4 text-primary"></i> 
                        <span>{{ 'info.stock'|trans }} <strong class="text-body">{{ product.stock }}</strong></span>
                    </li>
                {% endif %}
                {% if product.weight %}
                    <li class="d-flex align-items-center gap-3">
                        <i class="bi bi-speedometer2 fs-4 text-primary"></i> 
                        <span>{{ 'info.weight'|trans }} <strong class="text-body">{{ product.weight }} kg</strong></span>
                    </li>
                {% endif %}
                {% if product.origin %}
                    <li class="d-flex align-items-center gap-3">
                        <i class="bi bi-geo-alt-fill fs-4 text-primary"></i> 
                        <span>{{ 'info.origin'|trans }} <strong class="text-body">{{ product.origin }}</strong></span>
                    </li>
                {% endif %}
                {% if product.expiresAt %}
                    <li class="d-flex align-items-center gap-3">
                        <i class="bi bi-calendar-event fs-4 text-primary"></i> 
                        <span>{{ 'info.expires'|trans }} <strong class="text-body">{{ product.expiresAt|date('d/m/Y') }}</strong></span>
                    </li>
                {% endif %}
            </ul>
        </div>

        {% if product.description %}
            <div class="mb-4">
                <h5 class="fw-bold mb-3">Description</h5>
                <p class="text-muted" style="line-height: 1.7;">{{ product.description|nl2br }}</p>
            </div>
        {% endif %}

        <div class="card seller-card mb-4 p-2">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi bi-person-circle fs-2 text-muted"></i>
                    <div>
                        <p class="mb-0 text-muted small">{{ 'info.sold_by'|trans }}</p>
                        <a href="{{ path('app_seller_show', {id: product.seller.id}) }}" class="fw-bold text-body text-decoration-none fs-5">
                            {{ product.seller.firstName }} {{ product.seller.lastName }}
                        </a>
                        <p class="mb-0 text-muted small mt-1">{{ 'published_on_date'|trans }} {{ product.createdAt|date('d/m/Y') }}</p>
                    </div>
                </div>
                {% set rating = product.seller.averageRating ?? 0 %}
                {% set reviewCount = product.seller.reviewsReceived|length %}
                <div class="text-end">
                    <div class="d-flex align-items-center justify-content-end gap-1 mb-1">
                        <i class="bi bi-star-fill text-warning fs-5"></i>
                        <span class="fw-bolder fs-4">{{ rating|number_format(1, ',', ' ') }}</span>
                    </div>
                    {% if reviewCount > 0 %}
                        <span class="badge bg-secondary rounded-pill">{{ reviewCount }} {{ 'info.reviews'|trans }}</span>
                    {% else %}
                        <span class="badge bg-light text-dark border">{{ 'info.new_seller'|trans }}</span>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            {% if app.user and app.user !== product.seller %}
                {% include 'cart/_add_form.html.twig' %}
                {% set isFav = app.user.favorites|filter(f => f.product.id == product.id)|length > 0 %}
                <form method="post" action="{{ path('app_account_favorite_toggle', {id: product.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('favorite-' ~ product.id) }}">
                    <button class="btn action-btn rounded-pill w-100 {% if isFav %}btn-danger shadow{% else %}btn-outline-danger{% endif %} d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-heart{% if isFav %}-fill{% endif %} fs-5"></i>
                        <span class="fw-bold">{% if isFav %}{{ 'button.remove_from_favorites'|trans }}{% else %}{{ 'button.add_to_favorites'|trans }}{% endif %}</span>
                    </button>
                </form>
            {% endif %}

            {% if app.user == product.seller %}
                <div class="d-flex gap-3 mt-3">
                    <a href="{{ path('app_product_edit', {id: product.id}) }}"
                       class="btn btn-outline-secondary action-btn flex-fill"><i class="bi bi-pencil me-2"></i>{{ 'button.edit'|trans }}</a>
                    <form method="post"
                          action="{{ path('app_product_delete', {id: product.id}) }}"
                          onsubmit="return confirm('{{ 'message.confirm_delete_product'|trans }}')" class="flex-fill">
                        <input type="hidden" name="_token"
                               value="{{ csrf_token('delete-product-' ~ product.id) }}">
                        <button class="btn btn-outline-danger action-btn w-100"><i class="bi bi-trash me-2"></i>{{ 'button.delete'|trans }}</button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
